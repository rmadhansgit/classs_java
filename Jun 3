import java.util.Scanner;

// Custom Exception
class InsufficientBalanceException extends Exception {
    public InsufficientBalanceException(String message) {
        super(message);
    }
}

public class ATMSystem {
    static double balance = 10000.00;
    static Scanner sc = new Scanner(System.in);

    public static void withdraw(double amount) throws InsufficientBalanceException {
        if (amount > balance) {
            throw new InsufficientBalanceException(
                "Insufficient balance! Available: " + balance);
        }
        balance -= amount;
        System.out.println("Withdrawal successful! Remaining balance: " + balance);
    }

    public static void main(String[] args) {
        int choice;
        do {
            System.out.println("\n--- ATM MENU ---");
            System.out.println("1. Withdraw Money");
            System.out.println("2. Check Balance");
            System.out.println("3. Exit");
            System.out.print("Enter choice: ");
            choice = sc.nextInt();

            switch (choice) {
                case 1:
                    System.out.print("Enter amount to withdraw: ");
                    double amount = sc.nextDouble();
                    try {
                        withdraw(amount);
                    } catch (InsufficientBalanceException e) {
                        System.out.println("Error: " + e.getMessage());
                    }
                    break;

                case 2:
                    System.out.println("Current Balance: " + balance);
                    break;

                case 3:
                    System.out.println("Thank you. Goodbye!");
                    break;

                default:
                    System.out.println("Invalid choice!");
            }
        } while (choice != 3);

    }
}

2) import java.util.Scanner;

// Custom Exception
class AccountLockedException extends Exception {
    public AccountLockedException(String message) {
        super(message);
    }
}

public class LoginSystem {
    static final String CORRECT_USERNAME = "admin";
    static final String CORRECT_PASSWORD = "1234";
    static final int MAX_ATTEMPTS = 3;
    static Scanner sc = new Scanner(System.in);

    public static void login(String user, String pass, int attemptsLeft)
            throws AccountLockedException {

        if (attemptsLeft == 0) {
            throw new AccountLockedException(
                "Account locked! Too many failed attempts.");
        }

        if (user.equals(CORRECT_USERNAME) && pass.equals(CORRECT_PASSWORD)) {
            System.out.println("Login successful! Welcome, " + user);
        } else {
            System.out.println("Invalid credentials! Attempts remaining: "
                + (attemptsLeft - 1));
            throw new AccountLockedException("Incorrect credentials.");
        }
    }

    public static void main(String[] args) {
        int attempts = MAX_ATTEMPTS;
        boolean loggedIn = false;
        int choice;

        do {
            System.out.println("\n--- LOGIN MENU ---");
            System.out.println("1. Login");
            System.out.println("2. Exit");
            System.out.print("Enter choice: ");
            choice = sc.nextInt();

            if (choice == 1) {
                if (attempts == 0) {
                    System.out.println("Account is locked! No more attempts.");
                    break;
                }
                System.out.print("Username: ");
                String user = sc.next();
                System.out.print("Password: ");
                String pass = sc.next();

                try {
                    login(user, pass, attempts);
                    loggedIn = true;
                    break;
                } catch (AccountLockedException e) {
                    attempts--;
                    if (attempts == 0) {
                        System.out.println("Account LOCKED!");
                    }
                }

            } else if (choice == 2) {
                System.out.println("Exiting...");
            } else {
                System.out.println("Invalid choice!");
            }

        } while (choice != 2 && !loggedIn && attempts > 0);
    }

3) import java.util.ArrayList;
import java.util.Scanner;

public class StudentMarksSystem {
    static ArrayList<Integer> marksList = new ArrayList<>();
    static Scanner sc = new Scanner(System.in);

    public static void enterMarks(int marks) {
        if (marks < 0 || marks > 100) {
            throw new IllegalArgumentException(
                "Invalid marks! Marks must be between 0 and 100.");
        }
        marksList.add(marks);
        System.out.println("Marks " + marks + " added successfully!");
    }

    public static void displayMarks() {
        if (marksList.isEmpty()) {
            System.out.println("No marks available.");
        } else {
            System.out.println("Student Marks: " + marksList);
        }
    }

    public static void main(String[] args) {
        int choice;
        do {
            System.out.println("\n--- STUDENT MARKS MENU ---");
            System.out.println("1. Enter Student Marks");
            System.out.println("2. Display Marks");
            System.out.println("3. Exit");
            System.out.print("Enter choice: ");
            choice = sc.nextInt();

            switch (choice) {
                case 1:
                    System.out.print("Enter marks (0-100): ");
                    int marks = sc.nextInt();
                    try {
                        enterMarks(marks);
                    } catch (IllegalArgumentException e) {
                        System.out.println("Error: " + e.getMessage());
                    }
                    break;

                case 2:
                    displayMarks();
                    break;

                case 3:
                    System.out.println("Exiting...");
                    break;

                default:
                    System.out.println("Invalid choice!");
            }
        } while (choice != 3);
    }
}

        System.out.println("║  1. Add Member                          ║");
        System.out.println("║  2. Remove Member                       ║");
        System.out.println("║  3. Search Member                       ║");
        System.out.println("║  4. Display All Members                 ║");
        System.out.println("║  5. Count Members                       ║");
        System.out.println("║  6. Exit                                ║");

2)import java.util.*

class StudentClubManagementSystem {
    private Set<String> clubMembers;
    private Scanner scanner;
    
    // Constructor
    public StudentClubManagementSystem() {
        // Using HashSet to prevent duplicates
        this.clubMembers = new HashSet<>();
        this.scanner = new Scanner(System.in);
    }
    
    // 1. Add Member
    public void addMember() {
        System.out.println("\n========== ADD MEMBER ==========");
        
        System.out.print("Enter Member Name: ");
        String memberName = scanner.nextLine().trim();
        
        // Check if member already exists
        if (clubMembers.contains(memberName)) {
            System.out.println("❌ Member \"" + memberName + "\" already exists!");
            System.out.println("   (Set does not allow duplicates)");
        } else {
            clubMembers.add(memberName);
            System.out.println("✅ Member \"" + memberName + "\" added successfully!");
            System.out.println("   Total members: " + clubMembers.size());
        }
    }
    
    // 2. Remove Member
    public void removeMember() {
        System.out.println("\n========== REMOVE MEMBER ==========");
        
        System.out.print("Enter Member Name to Remove: ");
        String memberName = scanner.nextLine().trim();
        
        if (clubMembers.contains(memberName)) {
            clubMembers.remove(memberName);
            System.out.println("✅ Member \"" + memberName + "\" removed successfully!");
            System.out.println("   Total members: " + clubMembers.size());
        } else {
            System.out.println("❌ Member \"" + memberName + "\" not found!");
        }
    }
    
    // 3. Search Member
    public void searchMember() {
        System.out.println("\n========== SEARCH MEMBER ==========");
        
        System.out.print("Enter Member Name to Search: ");
        String memberName = scanner.nextLine().trim();
        
        if (clubMembers.contains(memberName)) {
            System.out.println("✅ Member \"" + memberName + "\" is present in the club!");
        } else {
            System.out.println("❌ Member \"" + memberName + "\" is NOT present in the club!");
        }
    }
    
    // 4. Display All Members
    public void displayAllMembers() {
        System.out.println("\n========== ALL CLUB MEMBERS ==========");
        
        if (clubMembers.isEmpty()) {
            System.out.println("❌ No members in the club yet!");
            return;
        }
        
        System.out.println("Total Members: " + clubMembers.size());
        System.out.println("-----------------------------------");
        
        int count = 1;
        for (String member : clubMembers) {
            System.out.println(count + ". " + member);
            count++;
        }
        System.out.println("-----------------------------------");
    }
    
    // 5. Count Members
    public void countMembers() {
        System.out.println("\n========== MEMBER COUNT ==========");
        int count = clubMembers.size();
        
        if (count == 0) {
            System.out.println("❌ The club has no members yet!");
        } else {
            System.out.println("✅ Total members in the club: " + count);
        }
    }
    
    // Display Menu
    public void displayMenu() {

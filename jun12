3)class UserSession {

    private static UserSession obj;
    private String userName;

    // private constructor
    private UserSession() {
    }

    // Singleton method
    public static UserSession getInstance() {
        if (obj == null) {
            obj = new UserSession();
        }
        return obj;
    }

    public void setUser(String name) {
        userName = name;
    }

    public void showUser() {
        System.out.println("User Name: " + userName);
    }
}


public class Main {
    public static void main(String[] args) {

        first reference
        UserSession user1 = UserSession.getInstance();
        user1.setUser("Madhan");

        second reference
        UserSession user2 = UserSession.getInstance();

        user2.showUser();

        checking same object
        System.out.println(user1 == user2);
    }
}

